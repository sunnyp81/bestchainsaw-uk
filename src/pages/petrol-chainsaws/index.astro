---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import Disclosure from '../../components/Disclosure.astro';
import HowWeResearch from '../../components/HowWeResearch.astro';
import { articleSchema, itemListSchema, faqSchema, breadcrumbSchema } from '../../lib/schema';

const title = 'Best Petrol Chainsaws UK 2026 - Buying Guide';
const description = 'Independent, research-led guide to the best petrol chainsaws for UK gardens and smallholdings: engine size, bar length, felling capability and who needs one.';
const datePublished = '2026-07-10';
const url = '/petrol-chainsaws/';

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Petrol chainsaws', url },
];

// TODO(content agent): replace with real, sourced FAQs.
const faqs: { q: string; a: string }[] = [];
// TODO(content agent): populate with real ranked PickCard picks once sourced; itemListSchema activates automatically.
const picks: { name: string; url: string }[] = [];

const schema = [
  articleSchema({ headline: title, description, url, datePublished, author: 'Sunny Patel' }),
  ...(picks.length ? [itemListSchema({ name: 'Best petrol chainsaws UK', url, items: picks.map((p, i) => ({ ...p, position: i + 1 })) })] : []),
  faqSchema(faqs),
  breadcrumbSchema(crumbs),
].filter(Boolean);
---
<BaseLayout {title} {description} {schema}>
  <article class="max-w-4xl mx-auto px-4 py-10">
    <Breadcrumbs items={crumbs} />
    <p class="text-sm font-semibold text-hazard-600 uppercase tracking-wide mb-2 font-heading">Petrol chainsaws</p>
    <h1 class="text-3xl md:text-5xl font-bold text-graphite-900 leading-tight font-heading">Best petrol chainsaws for felling and big jobs</h1>
    <p class="mt-5 text-lg text-steel-600 leading-relaxed">
      For felling, thick rounds and cutting all day away from a power source, petrol is still the
      only realistic choice. This guide covers engine size (cc), bar length, and who genuinely
      needs a petrol saw rather than a battery one.
    </p>
    <Disclosure />

    <!-- TODO(content agent): full buying-guide prose, PickCard picks, PriceGrid comparisons, comparison table, sourced FAQs. -->
    <div class="my-12 rounded-xl border border-dashed border-steel-400 bg-surface-100 p-6 text-sm text-steel-600">
      Placeholder shell. Full guide content pending from the wave-1 content pipeline.
    </div>

    <HowWeResearch />
    <FAQ {faqs} />
  </article>
</BaseLayout>
