---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Disclosure from '../../components/Disclosure.astro';
import FAQ from '../../components/FAQ.astro';
import { personSchema, faqSchema, breadcrumbSchema } from '../../lib/schema';
import { SITE, POWER_TYPE_HUBS, SAFETY_LINK } from '../../lib/site';

const title = 'About Best Chainsaw: Who We Are and How We Research';
const description = 'Best Chainsaw is an independent UK guide by Sunny Patel. No staged tests: manufacturer specs, verified owner reviews, HSE/EN381 standards, UK pricing.';
const url = '/about/';

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'About', url },
];

const faqs = [
  {
    q: 'Who runs bestchainsaw.uk?',
    a: 'Best Chainsaw is written and published by Sunny Patel. Sunny is an independent UK publisher who runs a small portfolio of buying-guide sites. See <a href="/about/#who-runs-this-site">who runs this site</a> for the full picture.',
  },
  {
    q: 'How does bestchainsaw.uk make money?',
    a: 'Best Chainsaw makes money through the Amazon Associates UK affiliate programme. We may earn a small commission if you buy a chainsaw through a tagged link on this site at no extra cost to you. This never changes which product we recommend. See our <a href="/about/#affiliate-disclosure">affiliate disclosure</a> for details.',
  },
  {
    q: 'Has bestchainsaw.uk tested these chainsaws?',
    a: 'No, not in the sense of a staged hands-on test. We do not run a test lab or film saws cutting logs for a camera. Every recommendation is built from manufacturer specifications, verified UK owner and community reviews, HSE/EN381 safety standards and UK retail pricing. See <a href="/about/#how-we-research">how we research</a> for the full method.',
  },
];

// Organization, WebSite and Speakable schema are already injected globally by
// BaseLayout's orgSchema()/websiteSchema()/speakableSchema() calls on every page.
// This page, as the Organization/Person @id target, adds the Person entity plus
// its own FAQ and breadcrumb.
const schema = [
  personSchema(),
  faqSchema(faqs),
  breadcrumbSchema(crumbs),
].filter(Boolean);
---
<BaseLayout {title} {description} {schema}>
  <article class="max-w-3xl mx-auto px-4 py-10">
    <Breadcrumbs items={crumbs} />
    <p class="text-sm font-semibold text-hazard-600 uppercase tracking-wide mb-2 font-heading">About</p>
    <h1 class="text-3xl md:text-5xl font-bold text-graphite-900 leading-tight font-heading">About Best Chainsaw</h1>
    <p class="mt-5 text-lg text-steel-600 leading-relaxed">
      Best Chainsaw is an independent UK chainsaw buying-guide site published by {SITE.editor}.
      We do not run staged hands-on tests: every recommendation is built from manufacturer
      specifications, verified UK owner and community reviews, HSE and EN381 safety standards,
      and live UK retail pricing. The site's Fit Check tool then matches each recommendation to a
      real UK cutting task.
    </p>

    <section id="how-we-research" class="scroll-mt-24 my-10">
      <h2 class="text-xl md:text-2xl font-bold text-graphite-900 mb-3 font-heading">How we research</h2>
      <p class="text-steel-600 leading-relaxed mb-3">
        Every guide starts with the manufacturer's own published specification: bar length, chain
        pitch, weight, motor or engine power, and battery voltage where it applies. We check that
        figure against the spec sheet or manual, not a press release summary.
      </p>
      <p class="text-steel-600 leading-relaxed mb-3">
        We then read what real UK owners say once a saw is out of the box: threads on Arbtalk and
        other UK chainsaw, gardening and DIY forums, and verified buyer reviews on Amazon UK and
        major UK retailers. A recurring complaint carries more weight than a single five-star
        review: chain stretch, a bar oil leak, or battery runtime falling short of the claimed
        figure.
      </p>
      <p class="text-steel-600 leading-relaxed mb-3">
        Safety guidance is cross-checked against HSE guidance and the EN381 standard for
        protective clothing directly. We do not paraphrase it from another buying-guide site.
      </p>
      <p class="text-steel-600 leading-relaxed">
        Prices shown are current UK retail prices. We check them at the point of writing and
        refresh them when we revisit a page. A price can move within days of publishing; we flag
        it when a figure looks out of date.
      </p>

      <h3 class="text-lg font-bold text-graphite-900 mt-6 mb-2 font-heading">What we don't do</h3>
      <ul class="list-disc pl-5 space-y-2 text-steel-600 leading-relaxed">
        <li>
          We don't claim to have physically tested every saw on this site. Recommendations for a
          model we haven't put hands on still come from the sources above, not a staged test.
        </li>
        <li>
          We don't invent a named "expert tester" or arborist persona to sound more authoritative.
          The person behind this site is Sunny Patel (see below). That's the only name attached to
          it.
        </li>
        <li>
          We correct mistakes. We fix any spec, price or safety detail that turns out wrong or out
          of date rather than leave it live.
        </li>
      </ul>
    </section>

    <section id="who-runs-this-site" class="scroll-mt-24 my-10">
      <h2 class="text-xl md:text-2xl font-bold text-graphite-900 mb-3 font-heading">Who runs this site</h2>
      <p class="text-steel-600 leading-relaxed mb-3">
        Best Chainsaw is written and published by {SITE.editor}. Sunny is an SEO consultant and
        independent publisher who runs a small portfolio of UK buying-guide sites. Sunny compiles
        and cross-checks the recommendations on this site from the sources above: manufacturer
        specifications, UK owner and forum reviews, HSE and EN381 standards, and UK retail
        pricing.
      </p>
      <p class="text-steel-600 leading-relaxed">
        Sunny is not a professional arborist, tree surgeon or chainsaw technician. This site does
        not claim otherwise. Questions or corrections are welcome at
        <a href={`mailto:${SITE.email}`} class="text-hazard-600 underline underline-offset-2">{SITE.email}</a>.
      </p>
    </section>

    <section id="affiliate-disclosure" class="scroll-mt-24 my-10">
      <h2 class="text-xl md:text-2xl font-bold text-graphite-900 mb-3 font-heading">Affiliate disclosure</h2>
      <p class="text-steel-600 leading-relaxed mb-3">
        Best Chainsaw is reader-supported. Some links on this site are Amazon UK affiliate links
        (tag <code class="font-mono-spec text-sm">chainsaw0f6-21</code>). We may earn a commission
        if you buy through one at no extra cost to you. Commission never decides which product
        ranks first; our picks are set before any link is added.
      </p>
      <Disclosure />
    </section>

    <section id="editorial-standards" class="scroll-mt-24 my-10">
      <h2 class="text-xl md:text-2xl font-bold text-graphite-900 mb-3 font-heading">Editorial standards</h2>
      <p class="text-steel-600 leading-relaxed">
        We get details wrong sometimes. A manufacturer changes a spec between production runs, a
        retailer's price moves, or a safety reference gets updated. We correct the page when that
        happens. We don't run a public change log: we just fix it because an out of date spec is
        worse than no spec at all. Email
        <a href={`mailto:${SITE.email}`} class="text-hazard-600 underline underline-offset-2">{SITE.email}</a>
        with the page and the detail if you spot something wrong. We'll check it.
      </p>

      <!-- MANUAL: SITE.sameAs is intentionally empty until real, verified profiles (Companies
           House / Trustpilot / socials) exist. Do not fabricate. -->
    </section>

    <FAQ {faqs} />

    <nav aria-label="Explore Best Chainsaw" class="my-12">
      <h2 class="text-xl md:text-2xl font-bold text-graphite-900 mb-4 font-heading">Where to start</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {POWER_TYPE_HUBS.map((h) => (
          <a href={`/${h.slug}/`} class="block bg-white border border-steel-200 rounded-xl p-5 hover:border-hazard-500 hover:shadow-md transition">
            <strong class="text-graphite-900 font-heading">{h.label} chainsaws</strong>
            <span class="block mt-1 text-sm text-steel-600">Guide and picks</span>
          </a>
        ))}
        <a href={`/${SAFETY_LINK.slug}/`} class="block bg-white border border-steel-200 rounded-xl p-5 hover:border-hazard-500 hover:shadow-md transition">
          <strong class="text-graphite-900 font-heading">{SAFETY_LINK.label}</strong>
          <span class="block mt-1 text-sm text-steel-600">EN381 PPE and safe technique</span>
        </a>
        <a href="/#fit-check" class="block bg-white border border-steel-200 rounded-xl p-5 hover:border-hazard-500 hover:shadow-md transition">
          <strong class="text-graphite-900 font-heading">Fit Check tool</strong>
          <span class="block mt-1 text-sm text-steel-600">Match your task to a saw in seconds</span>
        </a>
      </div>
    </nav>
  </article>
</BaseLayout>
