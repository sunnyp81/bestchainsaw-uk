---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SchemaJsonLd from '../components/SchemaJsonLd.astro';
import { orgSchema, websiteSchema, speakableSchema } from '../lib/schema';
import { SITE } from '../lib/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
  schema?: unknown[];
}
const { title, description, canonical, noindex, ogImage, schema = [] } = Astro.props as Props;
const url = canonical ?? new URL(Astro.url.pathname, SITE.url).toString();
const og = ogImage ?? '/og-default.png';
const allSchema = [orgSchema(), websiteSchema(), speakableSchema(url), ...schema].filter(Boolean);
---
<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@700;800;900&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet" />
  <!-- MANUAL: replace with real bestchainsaw.uk GA4 Measurement ID -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XXXXXXXXXX'); // MANUAL: replace with real bestchainsaw.uk GA4 Measurement ID
  </script>
  <!-- Affiliate outbound-click tracking: fires affiliate_click on any sponsored/Amazon link -->
  <script is:inline>
    document.addEventListener('click', function (e) {
      var a = e.target && e.target.closest ? e.target.closest('a[href]') : null;
      if (!a) return;
      var rel = a.getAttribute('rel') || '';
      var href = a.href || '';
      if (rel.indexOf('sponsored') === -1 && href.indexOf('amazon.') === -1) return;
      if (typeof gtag !== 'function') return;
      gtag('event', 'affiliate_click', {
        link_url: href,
        link_text: (a.textContent || '').trim().slice(0, 100),
        page_path: location.pathname,
        merchant: href.indexOf('amazon.') !== -1 ? 'amazon' : 'other'
      });
    }, true);
  </script>
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  {noindex && <meta name="robots" content="noindex,follow" />}
  <meta property="og:type" content="article" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={url} />
  <meta property="og:image" content={new URL(og, SITE.url).toString()} />
  <meta property="og:locale" content={SITE.locale} />
  <meta property="og:site_name" content={SITE.name} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <SchemaJsonLd data={allSchema as Record<string, unknown>[]} />
  <slot name="head" />
</head>
<body class="min-h-screen flex flex-col font-sans">
  <Header />
  <main id="main-content" class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
