---
// Multi-retailer UK price comparison (core USP artifact). Data-driven from
// src/data/priceGrid.ts so every price + product URL lives in one verifiable
// place and can be refreshed on a schedule.
//
// HONESTY RULES (non-negotiable, this ships to a live buying-guide):
//  - Every retailer URL is a REAL, verified product-page deep link, never a
//    search page and never fabricated. A retailer that does not genuinely stock
//    the model is simply omitted.
//  - Prices are dated indicative snapshots, not a live feed. A static site
//    cannot show a truly live price, so we show the figure we actually read on
//    the page, stamp the date it was checked, and deep-link to the live price.
//  - Amazon links carry the affiliate tag + rel="sponsored" (we earn a small
//    commission). Other retailers are NOT affiliate here, so they get a plain
//    rel="nofollow" - calling them "sponsored" would be untrue.
import { AFFILIATE_REL, amazonSearch, amazonLink, amazonImage } from '../lib/affiliate';
import { PRICE_GRID } from '../data/priceGrid';

interface Props { modelKey: string }
const { modelKey } = Astro.props as Props;
const entry = PRICE_GRID[modelKey];
if (!entry) throw new Error(`PriceGrid: no data for modelKey "${modelKey}" in src/data/priceGrid.ts`);
const thumb = amazonImage(entry.rows.find((r) => r.retailer === 'Amazon UK')?.asin);

const RETAILER_REL = 'nofollow noopener noreferrer';
const checkedLabel = new Date(entry.checked + 'T00:00:00Z').toLocaleDateString('en-GB', {
  day: 'numeric', month: 'short', year: 'numeric', timeZone: 'UTC',
});

// Amazon rows are tagged (affiliate): a verified ASIN builds a deep dp link,
// otherwise a tagged search fallback. Non-Amazon rows use their verified
// product URL verbatim and a plain (non-affiliate) rel.
const rows = entry.rows.map((r) => {
  const isAmazon = r.retailer === 'Amazon UK';
  const url = isAmazon
    ? (r.asin ? amazonLink(r.asin) : amazonSearch(entry.model))
    : r.url;
  return {
    ...r,
    url,
    rel: isAmazon ? AFFILIATE_REL : RETAILER_REL,
    cta: isAmazon ? (r.asin ? 'View on Amazon' : 'Search on Amazon') : 'View product',
  };
}).filter((r) => r.url);
---
<div class="my-8 border border-steel-200 rounded-xl overflow-hidden bg-white">
  <div class="bg-graphite-900 text-surface-50 px-4 py-2.5 flex flex-wrap items-center justify-between gap-x-4 gap-y-1">
    <span class="flex items-center gap-3">
      {thumb && <img src={thumb} alt={entry.model} loading="lazy" decoding="async" width="40" height="40" class="bg-white rounded object-contain p-0.5" />}
      <span class="text-sm font-semibold font-heading">Where to buy: {entry.model}</span>
    </span>
    <span class="text-xs text-steel-200">Prices checked {checkedLabel}</span>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-surface-100 text-left">
          <th scope="col" class="px-4 py-2 font-semibold text-graphite-900 text-xs uppercase tracking-wide">Retailer</th>
          <th scope="col" class="px-4 py-2 font-semibold text-graphite-900 text-xs uppercase tracking-wide">Price</th>
          <th scope="col" class="px-4 py-2 font-semibold text-graphite-900 text-xs uppercase tracking-wide">What you get</th>
          <th scope="col" class="px-4 py-2"><span class="sr-only">Buy link</span></th>
        </tr>
      </thead>
      <tbody>
        {rows.map((r) => (
          <tr class="border-t border-steel-200 hover:bg-surface-100">
            <td class="px-4 py-3 font-medium text-graphite-900">{r.retailer}</td>
            <td class="px-4 py-3 font-mono-spec text-graphite-900 whitespace-nowrap">{r.price ?? 'Check price'}</td>
            <td class="px-4 py-3 text-steel-600 text-xs">{r.note ?? '-'}</td>
            <td class="px-4 py-3 text-right">
              <a href={r.url} rel={r.rel} target="_blank" class="inline-block bg-hazard-500 hover:bg-hivis-400 text-graphite-900 text-xs font-bold px-3 py-1.5 rounded min-h-[36px]">
                {r.cta} &rarr;
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {entry.note && (
    <p class="px-4 py-2 text-xs text-steel-600 border-t border-steel-200 bg-hazard-50">{entry.note}</p>
  )}
  <p class="px-4 py-2 text-xs text-steel-400 border-t border-steel-200">
    Indicative prices from the dates shown, not a live feed. Stock and prices change often, so we deep-link each
    listing and let the retailer show the current price. As an Amazon Associate we earn from qualifying Amazon purchases.
  </p>
</div>
