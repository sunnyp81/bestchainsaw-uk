---
// ASA/FTC affiliate disclosure - place near the top of every money page.
interface Props { compact?: boolean }
const { compact = false } = Astro.props as Props;
---
<aside class={`flex items-start gap-2 rounded-lg border border-hivis-500/50 bg-hivis-300/20 text-graphite-900 ${compact ? 'px-3 py-2 text-xs' : 'px-4 py-3 text-sm'} my-4`} role="note">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mt-0.5 shrink-0" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
  <p>
    <strong>Affiliate disclosure:</strong> Best Chainsaw is reader-supported. If you buy through an Amazon UK link on this page we may earn a commission, at no extra cost to you. It never affects our picks. <a href="/about/#affiliate-disclosure" class="underline font-medium">How this works</a>.
  </p>
</aside>
