---
interface Props {
  rank: number;
  name: string;
  brand: string;
  bestFor: string;
  rating: number;
  pros: string[];
  cons: string[];
  rrp?: string;
  reviewUrl: string;
  affiliateUrl?: string;
  image?: string;
  verdict: string;
  // Dealer-channel models (Stihl, Husqvarna petrol) are NOT sold on Amazon or
  // general online retail in the UK. For those, pass dealerUrl (+ dealerLabel)
  // to render an honest non-affiliate "find a dealer" CTA instead of a tagged
  // Amazon link that would land on used/grey-import/parts listings.
  dealerUrl?: string;
  dealerLabel?: string;
}
import { AFFILIATE_REL, amazonSearch } from '../lib/affiliate';
const { rank, name, brand, bestFor, rating, pros, cons, rrp, reviewUrl, affiliateUrl, image, verdict, dealerUrl, dealerLabel } = Astro.props as Props;
const isDealer = Boolean(dealerUrl);
// Amazon path is affiliate (rel sponsored). Dealer path is a plain reference
// link (rel nofollow), never marked sponsored since we earn nothing on it.
const buyUrl = isDealer ? dealerUrl! : (affiliateUrl || amazonSearch(`${name} chainsaw`));
const buyRel = isDealer ? 'nofollow noopener noreferrer' : AFFILIATE_REL;
const buyLabel = isDealer ? (dealerLabel || 'Find an approved dealer') : 'Check price on Amazon';
---
<article class="border border-steel-200 rounded-xl bg-white overflow-hidden shadow-sm">
  <div class="grid md:grid-cols-[200px_1fr] gap-0">
    <div class="bg-hazard-50 flex items-center justify-center p-6 md:p-4 relative">
      <span class="absolute top-3 left-3 bg-hazard-600 text-white text-xs font-bold px-2 py-1 rounded">#{rank}</span>
      {image ? (
        <img src={image} alt={name} loading="lazy" width="180" height="180" class="object-contain max-h-44" />
      ) : (
        <div class="w-32 h-32 rounded-lg bg-hazard-100 flex items-center justify-center text-hazard-600 text-3xl font-bold font-heading">{brand.slice(0,1)}</div>
      )}
    </div>
    <div class="p-5">
      <div class="flex items-start justify-between gap-3 mb-2">
        <div>
          <span class="inline-block text-xs font-semibold text-hazard-600 uppercase tracking-wide mb-1">Best for {bestFor}</span>
          <h3 class="text-xl font-bold text-graphite-900 leading-tight font-heading">{name}</h3>
          <p class="text-sm text-steel-400">{brand}</p>
        </div>
        <div class="text-right shrink-0">
          <div class="text-hazard-600 text-lg" aria-label={`${rating} out of 5`}>
            {'★'.repeat(Math.round(rating))}<span class="text-steel-200">{'★'.repeat(5 - Math.round(rating))}</span>
          </div>
          {rrp && <div class="text-sm font-semibold text-graphite-900 mt-1 font-mono-spec">{rrp}</div>}
        </div>
      </div>
      <p class="text-steel-600 text-sm md:text-base mb-4 leading-relaxed">{verdict}</p>
      <div class="grid sm:grid-cols-2 gap-3 mb-4 text-sm">
        <div>
          <h4 class="font-semibold text-hazard-600 mb-1">Pros</h4>
          <ul class="space-y-0.5 text-steel-600">{pros.map((p) => (<li>+ {p}</li>))}</ul>
        </div>
        <div>
          <h4 class="font-semibold text-danger-600 mb-1">Cons</h4>
          <ul class="space-y-0.5 text-steel-600">{cons.map((c) => (<li>&minus; {c}</li>))}</ul>
        </div>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href={reviewUrl} class="inline-flex items-center gap-1 text-sm font-semibold text-hazard-600 hover:text-hazard-700 underline underline-offset-2">Read full review →</a>
        <a href={buyUrl} rel={buyRel} target="_blank" class="ml-auto inline-flex items-center gap-1 text-sm font-bold bg-hazard-500 hover:bg-hivis-400 text-graphite-900 px-3 py-1.5 rounded min-h-[44px]">
          {buyLabel} →
        </a>
      </div>
    </div>
  </div>
</article>
